<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <Button
        android:id="@+id/boutonCharger"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_charger" />

    <Button
        android:id="@+id/boutonSynchroniser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/btn_synchroniser" />

    <EditText
        android:id="@+id/champRecherche"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="@string/hint_recherche"
        android:inputType="text"
        android:maxLines="1" />

    <Button
        android:id="@+id/boutonChercher"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/btn_chercher" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/listeContacts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp" />

</LinearLayout>
